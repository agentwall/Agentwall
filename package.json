{
  "name": "agentwall",
  "version": "0.4.0",
  "description": "Policy-enforcing MCP proxy — intercepts AI agent tool calls before they execute",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "agentwall": "dist/cli.js"
  },
  "files": [
    "dist/",
    "index.js",
    "src/hook.js",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "ai",
    "agents",
    "safety",
    "claude",
    "cursor",
    "tool-approval"
  ],
  "license": "MIT",
  "openclaw": {
    "extensions": [
      "./index.js"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "js-yaml": "^4.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
